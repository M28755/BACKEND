<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LOGIN PAGE</title>
    <!--style links-->
    <link rel="stylesheet" href="style.css">
    <!--font link-->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Bungee&family=Bungee+Spice&family=Gravitas+One&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
    <!--icon link-->

</head>

<body>
    <header>
        <h1><a href="/">OUR APP</a></h1>
         <nav>
            <button><a href="/login">login</a></button>
         </nav>
    </header>
    <main>
        <form action="/register" method="POST">
        <fieldset>
            <label for="username"><small>Username</small></label>
            <input type="text" name="username" id="username" autocomplete="off">

             <label for="password"><small>Password</small></label>
            <input type="password" name="password" id="password" autocomplete="off">

           <br>
           <button>Sign up</button>
        </fieldset>
        </form>
    </main>
    


    <script src="script.js"></script>
</body>

</html>